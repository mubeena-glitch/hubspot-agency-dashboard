# ─────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/hubspot_dashboard
# Vercel: Use Vercel Postgres (automatically set as DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/hubspot_dashboard"

# ─────────────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────
# OPTIONAL: OAuth Providers
# ─────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# ─────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="HubSpot Dashboard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
